{
    "name": "bundle-items-tab",
    "version": "1.0.0",
    "description": "XS extension that shows tab in editor with all the items added to a Bundle",
    "author": "RWS",
    "homepage": "https://www.rws.com",
    "license": "Apache-2.0",
    "type": "module",
    "main": "../dist/bundle-items-tab/main.js",
    "files": [
        "../dist/bundle-items-tab/*"
    ],
    "private": true,
    "scripts": {
        "build": "webpack --config ./webpack.prod.config.js --progress",
        "dev": "webpack serve --config ./webpack.dev.config.js --progress --env target=http://0.0.0.0:8080/ manifest=../manifest.json",
        "pack": "sites-extensions pack --manifest=../manifest.json --input=../dist --output=../",
        "prepack": "npm run build",
        "lint": "eslint . --fix && prettier --write \"src/**/*\""
    },
    "dependencies": {
        "@emotion/react": "11.14.0",
        "@emotion/styled": "11.14.0",
        "@mui/material": "5.16.7"
    },
    "peerDependencies": {
